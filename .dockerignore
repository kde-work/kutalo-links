# Git
.git
.gitignore

# Секреты (монтируются в runtime через volume backend/)
backend/.env
backend/.env.*
!backend/.env.example

# Frontend: зависимости и кэш собираются внутри образа
frontend/node_modules
frontend/.angular

# Backend: vendor ставится в образе links-php
backend/vendor

# IDE и артефакты
.idea
.vscode
*.log
.phpunit.result.cache
