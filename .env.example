# Kutalo Links service environment
APP_NAME="Kutalo Links"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://l.kutalo.test

DB_CONNECTION=mysql
DB_HOST=kutalo-mysql
DB_PORT=3306
DB_DATABASE=kutalo_links
DB_USERNAME=kutalo_app
DB_PASSWORD=your_mysql_app_password_here

SESSION_DRIVER=redis
CACHE_STORE=redis
QUEUE_CONNECTION=sync

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_PORT=6379

ADMIN_EMAIL=admin@kutalo.test
ADMIN_PASSWORD=change_me

SANCTUM_STATEFUL_DOMAINS=l.kutalo.test,l.kutalo.com
